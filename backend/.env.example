# Copy to .env and set values. Do not commit .env.

# Development: DEBUG=True, local ALLOWED_HOSTS
# Production: DEBUG=False, set ALLOWED_HOSTS to your domain(s)
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Use a strong SECRET_KEY in production (generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
# SECRET_KEY=your-secret-key

# Production only: comma-separated origins for CORS and CSRF (e.g. https://your-frontend.com)
# CORS_ALLOWED_ORIGINS=https://your-frontend.com
# CSRF_TRUSTED_ORIGINS=https://your-frontend.com

# Optional: database path (default: backend/db.sqlite3)
# DB_PATH=db.sqlite3

# When True, dietary and food-type preferences are applied as hard filters
# on venue querysets. Keep this off until venue seed data has had
# `populate_tags` run against real Google Places types, otherwise strict
# filtering can zero out preview / swipe results.
# STRICT_PREFERENCE_FILTERS=False

# PostgreSQL (set DB_ENGINE to switch from SQLite)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=mealswipe
# DB_USER=
# DB_PASSWORD=
# DB_HOST=
# DB_PORT=5432

# email (default: console backend)
# EMAIL_BACKEND=accounts.smtp_backend.CertifiSMTPBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=<your-email>@gmail.com
# EMAIL_HOST_PASSWORD=<your-gmail-app-password>
# DEFAULT_FROM_EMAIL=<your-email>@gmail.com
