# Copy to .env and set values. Do not commit .env.

# Development: DEBUG=True, local ALLOWED_HOSTS
# Production: DEBUG=False, set ALLOWED_HOSTS to your domain(s)
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Use a strong SECRET_KEY in production (generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
# SECRET_KEY=your-secret-key

# Production only: comma-separated origins for CORS and CSRF (e.g. https://your-frontend.com)
# CORS_ALLOWED_ORIGINS=https://your-frontend.com
# CSRF_TRUSTED_ORIGINS=https://your-frontend.com

# Optional: database path (default: backend/db.sqlite3)
# DB_PATH=db.sqlite3

# Optional: email (default: console backend)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=your-sendgrid-api-key
# EMAIL_PORT=587
# DEFAULT_FROM_EMAIL=no-reply@example.com
